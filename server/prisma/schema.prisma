generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  avatar      String?
  bio         String?
  location    String?
  instruments     String[]
  mainInstrument  String?
  genres          String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts         Post[]
  followers     Follow[]       @relation("following")
  following     Follow[]       @relation("follower")
  conversations Conversation[] @relation("ConversationParticipants")
  sentMessages  Message[]
  bandMembers   BandMember[]
  reels              Reel[]
  reelLikes          ReelLike[]
  reelComments       ReelComment[]
  postLikes          PostLike[]
  comments           Comment[]
  sentNotifications     Notification[] @relation("NotificationFrom")
  receivedNotifications Notification[] @relation("NotificationTo")
  announcements         Announcement[]
  tracks                Track[]

  @@map("users")
}

model Post {
  id        String        @id @default(cuid())
  content   String
  mediaUrl  String?
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  comments  Comment[]
  notifications Notification[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("posts")
}

model Comment {
  id        String         @id @default(cuid())
  content   String
  authorId  String
  postId    String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  notifications Notification[]
  createdAt DateTime       @default(now())

  @@map("comments")
}

model PostLike {
  userId    String
  postId    String
  type      ReactionType
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@id([userId, postId, type])
  @@map("post_likes")
}

enum ReactionType {
  APLAUSO
  FIRE
  ASOMBRA
}

model Conversation {
  id           String    @id @default(cuid())
  participants User[]    @relation("ConversationParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  conversationId String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model Follow {
  followerId  String
  followingId String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@map("follows")
}

model Band {
  id          String       @id @default(cuid())
  name        String
  description String?
  genres      String[]
  location    String?
  avatar      String?
  banner      String?
  lookingFor  String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     BandMember[]

  @@map("bands")
}

model BandMember {
  id         String   @id @default(cuid())
  role       BandRole @default(MEMBER)
  instrument String?
  joinedAt   DateTime @default(now())
  userId     String
  bandId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  band       Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([userId, bandId])
  @@map("band_members")
}

enum BandRole {
  ADMIN
  MEMBER
}

enum NotificationType {
  FOLLOW
  POST_LIKE
  POST_COMMENT
  MENTION
  REEL_LIKE
  REEL_COMMENT
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  read       Boolean          @default(false)
  fromUserId String
  toUserId   String
  postId       String?
  commentId    String?
  reelId       String?
  reactionType ReactionType?
  from         User             @relation("NotificationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  to           User             @relation("NotificationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  post         Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment      Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  reel         Reel?            @relation(fields: [reelId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@map("notifications")
}

enum AnnouncementType {
  BUSCO_MUSICO
  BUSCO_BANDA
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  description String
  type        AnnouncementType
  instruments String[]
  genres      String[]
  location    String?
  authorId    String
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("announcements")
}

enum TrackType {
  AUDIO
  VIDEO
}

model Track {
  id        String    @id @default(cuid())
  title     String
  type      TrackType
  url       String
  publicId  String
  duration  Int?
  coverUrl  String?
  mimeType  String?
  fileSize  Int?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@map("tracks")
}

model Reel {
  id           String         @id @default(cuid())
  videoUrl     String
  thumbnailUrl String?
  publicId     String
  caption      String?
  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes        ReelLike[]
  reelComments ReelComment[]
  notifications Notification[]
  createdAt    DateTime       @default(now())

  @@map("reels")
}

model ReelComment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  reelId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("reel_comments")
}

model ReelLike {
  userId    String
  reelId    String
  type      ReactionType
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel      Reel         @relation(fields: [reelId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@id([userId, reelId, type])
  @@map("reel_likes")
}
